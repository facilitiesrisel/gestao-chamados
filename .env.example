# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP settings for sending emails (Gmail App Password)
# O sistema usa Gmail SMTP como fallback quando SENDGRID_API_KEY não está configurada.
SMTP_USER="facilitiesrisel@gmail.com"
SMTP_PASS="YOUR_GMAIL_APP_PASSWORD"

# SendGrid API Key (Opcional - se configurado, tem prioridade sobre SMTP)
# Se não configurado, o sistema usa Gmail SMTP automaticamente.
# SENDGRID_API_KEY="YOUR_SENDGRID_API_KEY"

# Firebase Integration (Required for Cloud persistence on Render/Koyeb)
FIREBASE_PROJECT_ID="YOUR_FIREBASE_PROJECT_ID"
FIREBASE_DATABASE_ID="(default)"
# Cole o conteúdo do JSON da chave de conta de serviço (Service Account Key) em uma linha única
FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", "project_id": "...", "private_key_id": "...", "private_key": "...", "client_email": "...", ...}'

